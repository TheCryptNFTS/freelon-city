# ╭──────────────────────────────────────────────────────────────────╮
# │  FREELON CITY · VERCEL ENV TEMPLATE                              │
# │  Copy each KEY=VALUE into Vercel → Settings → Environment Vars   │
# │  (set each one for "Production" — and "Preview" if you want it   │
# │  to work on PR previews too).                                    │
# ╰──────────────────────────────────────────────────────────────────╯


# ─────────────────────────────────────────────────────────────────
# 1. REQUIRED — site won't work without these
# ─────────────────────────────────────────────────────────────────

# Random secret for daily-signal + sweep-bounty cron auth.
# This value was pre-generated for you — safe to use verbatim:
CRON_SECRET=76016affd9214fa0980f4ea380a0ad79d46b43cbdaad2d3f7566a3f36e14aa83

# Random secret for the /api/admin/preflight verifier.
# Pre-generated — safe to use verbatim:
ADMIN_PREFLIGHT_TOKEN=9c4794792b957d79bfc9256c37f2766158764608ae610afb

# OpenSea API key — sign up at https://docs.opensea.io/reference/api-keys
# Needed for: holder fallback, sales feed, red signal detection, civ stats
OPENSEA_API_KEY=<paste-your-opensea-key-here>

# Upstash Redis — sign up at https://upstash.com → create a Redis db →
# copy the REST URL + REST TOKEN.
# Needed for: hex balances, X verifications, watchlist, snipe flags,
# civ-wars counters, heat counters, rate limits.
# WITHOUT THESE: every store falls back to per-instance memory and
# data evaporates on every cold-start. Catastrophic for users.
UPSTASH_REDIS_REST_URL=https://<your-instance>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<paste-your-upstash-token>

# X OAuth 2.0 credentials — at https://developer.x.com/portal/projects-and-apps
#   1. Create a new App (or use existing)
#   2. Enable OAuth 2.0 → "User authentication settings"
#   3. App permissions: Read
#   4. Type of App: Web App
#   5. Callback URI / Redirect URL (must match EXACTLY):
#        https://freeloncity.com/api/x/callback
#   6. Website URL: https://freeloncity.com
X_OAUTH_CLIENT_ID=<paste-your-x-client-id>
X_OAUTH_CLIENT_SECRET=<paste-your-x-client-secret>

# Must match the Callback URL set in the X developer portal exactly.
X_OAUTH_REDIRECT_URI=https://freeloncity.com/api/x/callback

# The canonical site URL.
NEXT_PUBLIC_BASE_URL=https://freeloncity.com


# ─────────────────────────────────────────────────────────────────
# 2. RECOMMENDED — site degrades gracefully without these
# ─────────────────────────────────────────────────────────────────

# A reliable Ethereum RPC. Falling back to public RPCs is fine for
# correctness (we ride 4 of them via viem fallback) but a dedicated
# RPC makes the holder badge resolve in ~150ms instead of ~2-3s.
#
# Get one free at:
#   - https://www.alchemy.com  (recommended — copy "HTTPS" URL)
#   - https://www.infura.io
#   - https://www.quicknode.com
NEXT_PUBLIC_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/<your-key>


# ─────────────────────────────────────────────────────────────────
# 3. OPTIONAL — feature-specific (site fully works without)
# ─────────────────────────────────────────────────────────────────

# X API v1.1 OAuth 1.0a — only needed if you want the daily-signal cron
# to actually POST a tweet from @freeloncity. Without these, the cron
# returns a "dry-run" JSON instead of posting.
# Apply for elevated access on the X developer portal.
X_API_KEY=<optional>
X_API_SECRET=<optional>
X_ACCESS_TOKEN=<optional>
X_ACCESS_TOKEN_SECRET=<optional>

# Plausible analytics domain — leave unset to disable analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=<optional>
